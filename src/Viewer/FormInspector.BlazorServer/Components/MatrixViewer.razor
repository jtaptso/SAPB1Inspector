@using FormInspector.Application.DTOs

<div class="matrix-viewer">
    <h6 class="small text-muted">Matrix / Grid</h6>
    <div class="detail-grid">
        <div class="detail-row">
            <span class="detail-label">Matrix UID</span>
            <span class="detail-value"><code>@Matrix.MatrixUid</code></span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Row Count</span>
            <span class="detail-value">@Matrix.RowCount</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Editable</span>
            <span class="detail-value">@(Matrix.Editable ? "✅ Yes" : "❌ No")</span>
        </div>
    </div>

    @if (Matrix.Columns?.Count > 0)
    {
        <div class="matrix-columns mt-2">
            <h6 class="small text-muted">Columns (@Matrix.Columns.Count)</h6>
            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th>UID</th>
                            <th>Type</th>
                            <th>Caption</th>
                            <th>Binding</th>
                            <th>Editable</th>
                            <th>Width</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var col in Matrix.Columns)
                        {
                            <tr>
                                <td><code>@col.ColumnUid</code></td>
                                <td>@col.ColumnType</td>
                                <td>@col.Caption</td>
                                <td>
                                    @if (col.DataBinding is not null)
                                    {
                                        <code>@col.DataBinding.TableName.@col.DataBinding.ColumnName</code>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>@(col.Editable ? "✅" : "❌")</td>
                                <td>@col.Width</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public MatrixMetadataDto Matrix { get; set; } = null!;
}
